#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cout << "ENTER A STRING : ";
    cin >> s;

    int freq[256] = {0};

    for (int i = 0; i < s.length(); i++)
        freq[(int)s[i]]++;

    char maxChar = s[0];
    int maxCount = 0;

    for (int i = 0; i < s.length(); i++) {
        if (freq[(int)s[i]] > maxCount) {
            maxCount = freq[(int)s[i]];
            maxChar = s[i];
        }
    }

    cout << "MAXIMUM OCCURING CHARACTER : " << maxChar << " (" << maxCount << " TIMES)" << endl;
    return 0;
}
