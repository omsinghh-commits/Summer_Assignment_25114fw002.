#include<iostream>
using namespace std;

int fib(int);

int main(){
    int n,i;
    cout<<"Enter n=";
    cin>>n;

    for(i=0;i<n;i++){
        cout<<fib(i)<<" ";

    }
    return 0;

}
int fib(int i){
    if(i==0)
    return 0;
    if(i==1)
    return 1;

    else
     return (fib(i-1) + fib(i-2));
     
}
