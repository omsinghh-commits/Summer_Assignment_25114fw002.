#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cout << "ENTER STRING : ";
    getline(cin, s);

    bool seen[256] = {false};  
    string result = "";

    for (int i = 0; i < s.length(); i++) {
        unsigned char ch = s[i];
        if (!seen[ch]) {
            seen[ch] = true;
            result += s[i];
        }
    }

    cout << "ORIGINAL STRING: " << s << endl;
    cout << "AFTER REMOVING DUPLICATES: " << result << endl;

    return 0;
}
