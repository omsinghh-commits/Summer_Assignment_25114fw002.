#include <iostream>
using namespace std;

int factorial(int n) {
    if(n==0 || n==1){
        return 1;
    }
    return n * factorial(n-1);
}

int main(){
    int n;
    cout << "ENTER NUMBER FOR FINDING FACTORIAL : ";
    cin >> n;

    if(n < 0){
        cout << "FACTORIAL IS NOT DEFINED : " << endl;
    }else{
        cout << "FACTORIAL OF "<< n << " = " << factorial(n) << endl;
    }

    return 0;
}
