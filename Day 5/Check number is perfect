#include <iostream>
using namespace std;

int main(){
    
    int num, sum = 1;

    cout << " ENTER A NUMBER : ";
    cin >> num;

    for(int i=2; i*i<=num; i++){
        if(num % i == 0){
            sum += i;
            if(i != num/i)
            sum += num/i;
        }
    }
   if(num > 1 && sum == num ){
    cout << num << " IS A PERFECT NUMBER:" << endl;
   }else{
    cout << num << " IS NOT A PERFECT NUMBER:" << endl; 
   }

   return 0;
}
