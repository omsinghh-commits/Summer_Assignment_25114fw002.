#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "ENTER SIZE OF ARRAY : ";
    cin >> n;

    int arr[n];
    cout << "ENTER ELEMENTS : ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int j = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0) {
            arr[j] = arr[i];
            j++;
        }
    }

    while (j < n) {
        arr[j] = 0;
        j++;
    }

    cout << "ARRAY AFTER MOVING ZEROES TO END : ";
    for (int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }
    cout << endl;

    return 0;
}
